include ../../Makefile.conf

APP = hello
APP_BUILD_DIR := $(USER_BUILD_ROOT)/$(APP)
APP_BIN := $(BIN_DIR)/$(APP)

# Automatically find all .c files in the current folder
SRCS = $(wildcard *.c)
OBJS = $(patsubst %.c,$(APP_BUILD_DIR)/%.o,$(SRCS))
DEPS = $(OBJS:.o=.d)

all: $(APP_BIN)

$(APP_BIN): $(OBJS)
	$(CC) $(LDFLAGS) $(CRT0) $(OBJS) $(LIB_ARCHIVE) $(LIBSYS) -o $@

# Standard pattern rule for objects
$(APP_BUILD_DIR)/%.o: %.c | $(APP_BUILD_DIR)
	$(CC) $(CFLAGS) -Iinclude -c $< -o $@

# Rule to create the directory
$(APP_BUILD_DIR):
	@mkdir -p $@

clean:
	rm -rf $(APP_BUILD_DIR)

# Include the dependency files generated by -MMD
-include $(DEPS)